QUES-1  Write a program to Calculate sum of first N natural numbers.	


#include <stdio.h>

int main() {
        int n, sum = 0;
            printf("Enter N: ");
                scanf("%d", &n);
                    for (int i = 1; i <= n; i++)
                            sum += i;
                                printf("Sum = %d\n", sum);
                                    return 0;
}
}